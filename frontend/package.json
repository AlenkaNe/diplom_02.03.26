{
    "name": "food-search-frontend",
    "version": "1.0.0",
    "description": "Интерфейс для поиска продуктов через API",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "set NODE_ENV=test&& jest",
        "test:coverage": "set NODE_ENV=test&& jest --coverage",
        "test:e2e": "playwright test --config=e2e/playwright.config.js",
        "test:e2e:ui": "playwright test --config=e2e/playwright.config.js --ui",
        "test:e2e:install-browsers": "playwright install chromium"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.6",
        "dotenv": "^17.2.3",
        "express": "^4.18.2",
        "http-proxy-middleware": "^2.0.6",
        "jsonwebtoken": "^9.0.2",
        "pg": "^8.11.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.51.0",
        "jest": "^30.3.0",
        "nodemon": "^3.0.1",
        "pg-mem": "^3.0.14",
        "supertest": "^7.2.2"
    }
}
